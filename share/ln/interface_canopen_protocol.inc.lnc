requires_version 0.2.43
# this include file can be customized with the following defines:
#   service_provider_canopen_protocol_base
#     (optional) path to service_provider_canopen_protocol base directory
#     e.g. /volume/software/robotkernel/packages/service_provider_canopen_protocol/5.0.0
#     defaults to rmpm structure
#   service_provider_canopen_protocol_libdir
#     (optional) add custom module search paths

defines
service_provider_canopen_protocol_base: %(dirname %(dirname %(CURDIR)))
service_provider_canopen_protocol_base_type: %(ifexists "%(service_provider_canopen_protocol_base)/lib/libservice_provider_canopen_protocol.so", "local_install", "rmpm_release")
service_provider_canopen_protocol_libdir: %(ifeq "%(service_provider_canopen_protocol_base_type)", "local_install", "%(service_provider_canopen_protocol_base)/lib", "%(service_provider_canopen_protocol_base)/lib/$(ARCH)")

ifndef rk_service_providers: rk_service_providers: ""
rk_service_providers: %(rk_service_providers):%(service_provider_canopen_protocol_libdir)

