services:
  - name: service_provider_canopen_protocol/read_element
    request:
      index: { type: uint16_t }
      sub_index: { type: uint8_t, default: 0 }
    response:
      name: { type: string }
      value_info: { type: uint8_t }
      data_type: { type: uint16_t }
      bit_length: { type: uint16_t }
      obj_access: { type: uint16_t }
      unit: { type: uint16_t }
      default_value: { type: string }
      min_value: { type: string }
      max_value: { type: string }
      value: { type: string }
      error_message: { type: string, default: "no error" }

