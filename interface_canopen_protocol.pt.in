PTVERSION           = 2
NAME                = @PACKAGE@
VERSION             = @VERSION@
DESCRIPTION         = robotkernel @PACKAGE@
MAINTAINER          = @MAINTAINER@
DOCUMENTATION       = https://rmintra01.robotic.dlr.de/wiki/Robotkernel/interface_canopen_protocol 
ARCHS               = @ARCHS@
SUPPORTED_LANGUAGES = C
C_INCLUDE_PATHS     = ${PKGROOT}/include/
C_LIB_PATHS         = ${PKGROOT}/lib/${ARCH}
C_LIBS              = 

[install]
build/${ARCH}/install/lib => lib/${ARCH}
doc/ => doc/
share/ => share/
src/main/cpp/*.h => include/@PACKAGE@/
src/main/cpp/include/ => include/robotkernel/

